# MongoDB connection string (MongoDB Atlas hoặc local)
# Dùng Mongo trong Docker (docker compose up -d mongo):
#   MONGODB_URI=mongodb://localhost:27017/bloglist
#   TEST_MONGODB_URI=mongodb://localhost:27017/bloglist-test
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# Database dùng khi chạy test. BẮT BUỘC khác MONGODB_URI:
TEST_MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/bloglist-test?retryWrites=true&w=majority

# Cổng backend lắng nghe
PORT=3001

# Khoá bí mật để ký JWT (dùng chuỗi ngẫu nhiên đủ dài)
# Tạo bằng: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET=your-jwt-secret-here

# Chỉ cần khi chạy frontend ở origin khác (backend đã tự serve SPA).
# Nhiều origin thì ngăn cách bằng dấu phẩy.
# CORS_ORIGIN=http://localhost:5173
